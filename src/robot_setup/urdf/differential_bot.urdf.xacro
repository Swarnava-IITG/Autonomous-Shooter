<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="differential_bot">
    <xacro:property name="chassis_length" value="0.5" />
    <xacro:property name="chassis_width" value="0.3" />
    <xacro:property name="chassis_height" value="0.15" />
    <xacro:property name="chassis_mass" value="5.0" />

    <xacro:property name="wheel_radius" value="0.1" />
    <xacro:property name="wheel_length" value="0.04" />
    <xacro:property name="wheel_mass" value="0.5" />
    <xacro:property name="wheel_x_offset" value="${chassis_length/4}" />

    <link name="base_footprint"/>

    <link name="base_link">
        <inertial>
            <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
            <mass value="${chassis_mass}"/>
            <inertia ixx="${(1.0/12.0)*chassis_mass*(chassis_width*chassis_width+chassis_height*chassis_height)}" ixy="0.0" ixz="0.0" iyy="${(1.0/12.0)*chassis_mass*(chassis_length*chassis_length+chassis_height*chassis_height)}" iyz="0.0" izz="${(1.0/12.0)*chassis_mass*(chassis_width*chassis_width+chassis_length*chassis_length)}"/>
        </inertial>
        <visual>
            <geometry>
                <box size="${chassis_length} ${chassis_width} ${chassis_height}"/>
            </geometry>
            <material name="green_theme">
                <color rgba="0.15 0.3 0.1 1.0"/>
            </material>
        </visual>
        <collision>
            <geometry>
                <box size="${chassis_length} ${chassis_width} ${chassis_height}"/>
            </geometry>
        </collision>
    </link>

    <joint name="base_footprint_to_base_link_joint" type="fixed">
        <origin xyz="0.0 0.0 ${wheel_radius}" rpy="0.0 0.0 0.0"/>
        <parent link="base_footprint"/>
        <child link="base_link"/>
    </joint>

    <xacro:macro name="generate_wheel" params="side reflect">
        <link name="${side}_wheel">
            <inertial>
                <mass value="${wheel_mass}"/>
                <inertia ixx="${(1.0/12.0)*wheel_mass*(3.0*wheel_radius*wheel_radius+wheel_length*wheel_length)}" ixy="0.0" ixz="0.0" iyy="${(1.0/12.0)*wheel_mass*(3.0*wheel_radius*wheel_radius+wheel_length*wheel_length)}" iyz="0.0" izz="${0.5 * wheel_mass * wheel_radius * wheel_radius}"/>
            </inertial>
            <visual name="">
                <origin xyz="0.0 0.0 0.0" rpy="${pi/2} 0.0 0.0"/>
                <geometry>
                    <cylinder radius="${wheel_radius}" length="${wheel_length}"/>
                </geometry>
                <material name="dark_grey">
                    <color rgba="0.2 0.2 0.2 1.0"/>
                </material>
            </visual>
            <collision>
                <origin xyz="0.0 0.0 0.0" rpy="${pi/2} 0.0 0.0"/>
                <geometry>
                    <cylinder radius="${wheel_radius}" length="${wheel_length}"/>
                </geometry>
            </collision>
        </link>

        <joint name="${side}_wheel_joint" type="continuous">
            <origin xyz="${wheel_x_offset} ${reflect*(chassis_width/2+wheel_length/2)} 0.0" rpy="0.0 0.0 0.0"/>
            <parent link="base_link"/>
            <child link="${side}_wheel"/>
            <axis xyz="0.0 1.0 0.0"/>
        </joint>
    </xacro:macro>

    <xacro:generate_wheel side="left" reflect="1"/>
    <xacro:generate_wheel side="right" reflect="-1"/>

    <link name="laser_frame">
        <inertial>
            <mass value="0.1"/>
            <inertia ixx="0.001" ixy="0.0" ixz="0.0" iyy="0.001" iyz="0.0" izz="0.001"/>
        </inertial>
        <visual name="">
            <geometry>
                <box size="0.05 0.05 0.04"/>
            </geometry>
            <material name="black">
                <color rgba="0.0 0.0 0.0 1.0"/>
            </material>
        </visual>
        <collision>
            <geometry>
                <box size="0.05 0.05 0.04"/>
            </geometry>
        </collision>
    </link>

    <joint name="base_link_to_laser_joint" type="fixed">
        <origin xyz="0.15 0.0 0.25" rpy="0.0 0.0 0.0"/>
        <parent link="base_link"/>
        <child link="laser_frame"/>
    </joint>

    <link name="turret_base">
        <inertial>
            <mass value="0.5"/>
            <inertia ixx="0.001" ixy="0.0" ixz="0.0" iyy="0.001" iyz="0.0" izz="0.001"/>
        </inertial>

        <visual name="">
            <geometry>
                <cylinder radius="0.06" length="0.04"/>
            </geometry>
            <material name="dark_grey">
                <color rgba="0.6 0.4 0.0 1.0"/>
            </material>
        </visual>

        <collision>
            <geometry>
                <cylinder radius="0.06" length="0.04"/>
            </geometry>
        </collision>
    </link>
    
    <joint name="turret_pan_joint" type="revolute">
        <origin xyz="0.1 0.0 ${(chassis_height/2) + 0.02}" rpy="0.0 0.0 0.0"/>
        <parent link="base_link"/>
        <child link="turret_base"/>
        <axis xyz="0.0 0.0 1.0"/>
        <limit lower="-1.57" upper="1.57" effort="10.0" velocity="1.0"/>
    </joint>

    <link name="shooter_barrel">
        <inertial>
            <mass value="0.2"/>
            <inertia ixx="0.001" ixy="0.0" ixz="0.0" iyy="0.001" iyz="0.0" izz="0.001"/>
        </inertial>

        <visual name="">
            <origin xyz="0.1 0.0 0.0" rpy="0.0 ${pi/2} 0.0"/>
            <geometry>
                <cylinder radius="0.015" length="0.2"/>
            </geometry>
            <material name="dark_grey"/>
        </visual>

        <collision>
            <origin xyz="0.1 0.0 0.0" rpy="0.0 ${pi/2} 0.0"/>
            <geometry>
                <cylinder radius="0.015" length="0.2"/>
            </geometry>
        </collision>
    </link>

    <joint name="shooter_tilt_joint" type="revolute">
        <parent link="turret_base"/>
        <child link="shooter_barrel"/>
        <origin xyz="0.0 0.0 0.03" rpy="0.0 0.0 0.0"/>
        <axis xyz="0.0 -1.0 0.0"/> 
        <limit lower="-0.200" upper="0.785" effort="10.0" velocity="1.0"/>
    </joint>

    <link name="camera_frame">
        <inertial>
            <mass value="0.1"/>
            <inertia ixx="0.0004" ixy="0.0" ixz="0.0" iyy="0.0004" iyz="0.0" izz="0.0004"/>
        </inertial>
        <visual name="">
            <geometry>
                <box size="0.05 0.05 0.04"/>
            </geometry>
            <material name="red">
                <color rgba="0.8 0.0 0.0 1.0"/>
            </material>
        </visual>
        <collision>
            <geometry>
                <box size="0.05 0.05 0.04"/>
            </geometry>
        </collision>
    </link>

    <joint name="barrel_to_camera_joint" type="fixed">
        <origin xyz="0.05 0.0 0.03" rpy="0.0 0.0 0.0"/>
        <parent link="shooter_barrel"/>
        <child link="camera_frame"/>
    </joint>

    <gazebo>
        <plugin filename="gz-sim-diff-drive-system" name="gz::sim::systems::DiffDrive">
            <left_joint>left_wheel_joint</left_joint>
            <right_joint>right_wheel_joint</right_joint>
            <wheel_separation>${chassis_width+wheel_length}</wheel_separation>
            <wheel_radius>${wheel_radius}</wheel_radius>
            <topic>/cmd_vel</topic>
            <odom_topic>/odom</odom_topic>
            <tf_topic>/tf</tf_topic>
            <frame_id>odom</frame_id>
            <child_frame_id>base_footprint</child_frame_id>
        </plugin>

        <plugin filename="gz-sim-sensors-system" name="gz::sim::systems::Sensors">
            <render_engine>ogre2</render_engine>
        </plugin>

        <plugin filename="gz-sim-joint-state-publisher-system" name="gz::sim::systems::JointStatePublisher"/>

        <plugin filename="gz-sim-joint-position-controller-system" name="gz::sim::systems::JointPositionController">
            <joint_name>turret_pan_joint</joint_name>
            <topic>/turret/pan_cmd</topic>
            <p_gain>10.0</p_gain>
        </plugin>

        <plugin filename="gz-sim-joint-position-controller-system" name="gz::sim::systems::JointPositionController">
            <joint_name>shooter_tilt_joint</joint_name>
            <topic>/turret/tilt_cmd</topic>
            <p_gain>10.0</p_gain>
        </plugin>

        <plugin filename="libignition-gazebo-pose-publisher-system.so" name="ignition::gazebo::systems::PosePublisher">
            <publish_link_pose>true</publish_link_pose>
            <publish_visual_pose>false</publish_visual_pose>
            <publish_nested_model_pose>true</publish_nested_model_pose>
            <update_frequency>50</update_frequency>
        </plugin>

    </gazebo>

    <gazebo reference="laser_frame">
        <sensor name="lidar_sensor" type="gpu_lidar">
            <topic>/scan</topic>
            <update_rate>10</update_rate>
            <gz_frame_id>laser_frame</gz_frame_id>
            <always_on>true</always_on>
            <visualize>true</visualize>
            <lidar>
                <scan>
                    <horizontal>
                        <samples>360</samples>
                        <resolution>1</resolution>
                        <min_angle>-3.14159</min_angle>
                        <max_angle>3.14159</max_angle>
                    </horizontal>
                </scan>
                <range>
                    <min>0.12</min>
                    <max>10.0</max>
                    <resolution>0.01</resolution>
                </range>
            </lidar>
        </sensor>
    </gazebo>

    <gazebo reference="camera_frame"> 
        <sensor name="camera_sensor" type="camera">
            <topic>/camera/image_raw</topic>
            <update_rate>30.0</update_rate>
            <always_on>true</always_on>
            <visualize>true</visualize> 
            <camera>
                <horizontal_fov>1.396263</horizontal_fov> 
                <image>
                    <width>640</width>
                    <height>480</height>
                    <format>R8G8B8</format>
                </image>
                <clip>
                    <near>0.02</near>
                    <far>300</far>
                </clip>
                <noise>
                    <type>gaussian</type>
                    <mean>0.0</mean>
                    <stddev>0.007</stddev>
                </noise>
            </camera>
        </sensor>
    </gazebo>


    <link name="caster_wheel">
        <inertial>
            <mass value="0.1"/>
            <inertia ixx="0.0001" ixy="0.0" ixz="0.0" iyy="0.0001" iyz="0.0" izz="0.0001"/>
        </inertial>
        <visual>
            <geometry>
                <sphere radius="0.025"/>
            </geometry>
            <material name="dark_grey"/>
        </visual>
        <collision>
            <geometry>
                <sphere radius="0.025"/>
            </geometry>
        </collision>
    </link>

    <joint name="caster_wheel_joint" type="fixed">
        <origin xyz="${-chassis_length/2 + 0.05} 0.0 ${-chassis_height/2}" rpy="0.0 0.0 0.0"/>
        <parent link="base_link"/>
        <child link="caster_wheel"/>
    </joint>

    <gazebo reference="caster_wheel">
        <mu1 value="0.001"/>
        <mu2 value="0.001"/>
    </gazebo>

</robot>